# Copy this file to .env and update with your values

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-secret-key-here-change-this-in-production

# Performance Settings - BALANCED for quality and speed
MAX_WORKERS=8
MODEL_NAME=u2net

# Firebase Configuration (Authentication only)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Cloudflare R2 Storage (for processed image uploads)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_DOMAIN=

# Brevo Email Service (for OTP verification)
BREVO_API_KEY=xkeysib-YOUR-BREVO-API-KEY-HERE
BREVO_SENDER_EMAIL=noreply@sallulabs.com
