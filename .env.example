# Copy this file to .env and update with your values

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-secret-key-here-change-this-in-production

# Performance Settings - BALANCED for quality and speed
MAX_WORKERS=8
MODEL_NAME=u2net

# Firebase Configuration (Optional - for image storage)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Performance Tuning Options:
# For MAX SPEED (less quality):  MODEL_NAME=u2netp
# For MAX QUALITY (slower):      MODEL_NAME=u2net (current)
# For BALANCED (recommended):    Current settings
