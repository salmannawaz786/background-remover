# URL of the Flask backend that processes images (the bg-remover API).
# Default points to the local Flask server (port 5001, see server.py).
NEXT_PUBLIC_API_URL=http://localhost:5001

# Optional: Firebase web config. If omitted, the app fetches
# the config from {API_URL}/api/config at runtime.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=