{
  "name": "bg-remover-desktop",
  "version": "1.2.0",
  "description": "Offline Background Remover Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron . --expose-gc",
    "build": "electron-builder",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "publish:win": "electron-builder --win --publish always",
    "publish:mac": "electron-builder --mac --publish always",
    "release": "electron-builder --win --mac --publish always"
  },
  "author": "SalluLabs",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "javascript-obfuscator": "^4.1.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.981.0",
    "dotenv": "^16.6.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "sharp": "^0.32.6"
  },
  "build": {
    "appId": "com.sallulabs.bgremover",
    "productName": "BG Remover",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "birefnet_server_ts.py",
        "to": "birefnet_server_ts.py"
      },
      {
        "from": "birefnet_lite.pt",
        "to": "birefnet_lite.pt"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "SalluLabs",
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.graphics-design",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BG Remover"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "Johny111ishxb",
      "repo": "background-remover"
    },
    "asar": false,
    "compression": "maximum",
    "afterPack": "./build-scripts/obfuscate.js"
  }
}
