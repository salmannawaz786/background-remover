# Flask Configuration
PORT=5000
WORKERS=4
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=100
SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32

# Firebase Authentication
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudflare R2 Storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_DOMAIN=https://your-cdn-domain.com

# CORS - Add your Vercel frontend URLs (comma-separated)
EXTRA_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-preview-branch.vercel.app

# App URL (your Oracle Cloud server IP or domain)
APP_URL=http://YOUR_SERVER_IP
